# Murtaugh credentials — keep this file secret.
#
# This is ~/.config/murtaugh/.env. Every secret lives here; the YAML config
# files reference these variables as ${VAR} and never hold the values, so the
# `murtaugh troubleshoot` bundle (which collects the .yaml files) cannot leak
# them. A value exported in the real environment overrides the one here.
#
# Format: KEY=value, one per line. No quotes needed; no spaces around '='.

# --- Slack (required to run the gateway) ---
SLACK_APP_TOKEN=xapp-replace-me
SLACK_BOT_TOKEN=xoxb-replace-me

# --- LLM providers (only the ones your native agents use) ---
# The variable NAME is what an agent profile's `api_key_env:` points at.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# OpenAI/Anthropic-compatible third parties reuse the families above with a
# base_url override (set per-agent in agents.yaml). Give each its own key var:
# ZAI_API_KEY=
# DEEPSEEK_API_KEY=
# KIMI_API_KEY=

# --- External MCP servers (optional; referenced from mcp_servers[*].env) ---
# VAULTRE_TOKEN=
